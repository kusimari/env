#compdef rclone-env

_rclone-env() {
  local -a subcommands
  subcommands=(
    'remotes:List configured rclone remotes'
    'list:Alias for remotes'
    'add:Add a new remote interactively'
    'ls:List directories on a remote'
    'check:Check differences between source and dest'
    'copy:Copy with optimised defaults'
    'sync:Dry-run preview then sync with optimised defaults'
  )

  _remotes() {
    local -a remotes
    remotes=(${(f)"$(rclone listremotes 2>/dev/null)"})
    _describe 'remote' remotes
  }

  if (( CURRENT == 2 )); then
    _describe 'subcommand' subcommands
    return
  fi

  case "${words[2]}" in
    ls)
      if (( CURRENT == 3 )); then
        _remotes
      fi
      ;;
    check|copy|sync)
      # Complete remote names for both source and dest positions
      _remotes
      ;;
  esac
}

_rclone-env "$@"
